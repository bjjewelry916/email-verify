{
  "version": 2,
  "builds": [
    {
      "src": "api/verify.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/verify",
      "dest": "/api/verify.py"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
